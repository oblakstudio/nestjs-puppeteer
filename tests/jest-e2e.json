{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "tests/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tests/tsconfig.json" }]
  },
  "collectCoverageFrom": [
    "lib/**/*.ts",
    "!lib/**/index.ts",
    "!lib/interfaces/**"
  ],
  "coverageDirectory": "tests/coverage"
}
